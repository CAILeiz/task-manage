# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=taskmanage
DB_USER=root
DB_PASSWORD=your_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_make_it_different
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 日志配置
LOG_LEVEL=debug
